# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/redteam

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Attack library path — relative to the backend/ folder
ATTACK_LIBRARY_PATH=../attack-library

# LLM API keys — fill in whichever providers you are using
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Auth — generate a long random string for SECRET_KEY
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Debug mode
DEBUG=True